package-as: EverythingDelves

# Replace with your actual CurseForge project ID after creating the project
curse-id: 1519355

enable-nolib-creation: no

changelog-title: Everything Delves
manual-changelog:
  filename: .release_changelog.md
  markup-type: markdown

ignore:
  - .pkgmeta
  - .github
  - .gitignore
  - README.md
  - CHANGELOG.md
  - .vscode
  - screenshots
  - LICENSE
  - claude.md
  - .claude
  - .release_changelog.md
